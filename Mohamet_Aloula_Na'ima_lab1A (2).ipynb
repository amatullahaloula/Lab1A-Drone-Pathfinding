        "\n",
        "def plot_path(grid, start=None, goal=None, path=None, title=\"Grid Map\"):\n",
        "    arr = np.array(grid)\n",
        "    height, width = arr.shape\n",
        "    path_set = set(path) if path else set()\n",
        "    fig, ax = plt.subplots(figsize=(7, 7))\n",
        "    ax.set_xlim(0, width)\n",
        "    ax.set_ylim(height, 0)\n",
        "    ax.set_aspect(\"equal\")\n",
        "    ax.axis(\"off\")\n",
        "    ax.set_title(title)\n",
        "    for row in range(height):\n",
        "        for col in range(width):\n",
        "            state = (row, col)\n",
        "            if arr[row, col] == 1:\n",
        "                fill = (0.15, 0.15, 0.15)\n",
        "            elif start and state == start:\n",
        "                fill = (0.95, 0.20, 0.20)\n",
        "            elif goal and state == goal:\n",
        "                fill = (0.20, 0.70, 0.25)\n",
        "            elif state in path_set:\n",
        "                fill = (0.95, 0.90, 0.35)\n",
        "            else:\n",
        "                fill = (0.95, 0.95, 0.95)\n",
        "            rect = patches.Rectangle((col, row), 1, 1, linewidth=1,\n",
        "                                      edgecolor=(0.75, 0.75, 0.75),\n",
        "                                      facecolor=fill)\n",
        "            ax.add_patch(rect)\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# run all four algorithms\n",
        "bfs = BreadthFirstSearch()\n",
        "dfs = DepthFirstSearch()\n",
        "dls = DepthLimitedSearch()\n",
