        "class SearchAlgorithm(ABC):\n",
        "\n",
        "    # generate all child nodes from the current node\n",
        "    def expand(self, problem, node):\n",
        "        s = node.state\n",
        "        for action in problem.actions(s):\n",
        "            s_prime = problem.result(s, action)\n",
        "            cost = node.path_cost + problem.action_cost(s, action, s_prime)\n",
        "            yield Node(state=s_prime, parent=node, action=action, path_cost=cost)\n",
        "\n",
        "    @abstractmethod\n",
        "    def search(self, problem): pass"
      ],
      "metadata": {
        "id": "-6urByWrJDJJ"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class BreadthFirstSearch(SearchAlgorithm):\n",
        "    def search(self, problem):\n",
        "        algorithm = \"BFS\"\n",
        "        node = Node(problem.initial_state())\n",
        "        nodes_expanded = 0\n",
        "        max_frontier_size = 1\n",
        "\n",
        "        # check if the starting point is already the goal\n",
        "        if problem.is_goal(node.state):\n",
        "            return SearchResult(algorithm, \"success\", node, 0, 1)\n",
        "\n",
        "        # use a queue so we explore level by level\n",
        "        frontier = deque([node])\n",
        "        reached = {node.state}\n",
        "\n",
        "        while frontier:\n",
        "            node = frontier.popleft()\n",
        "            nodes_expanded += 1\n",
        "\n",
        "            for child in self.expand(problem, node):\n",
        "                s = child.state\n",
        "                if problem.is_goal(s):\n",
        "                    return SearchResult(algorithm, \"success\", child,\n",
        "                                        nodes_expanded, max_frontier_size,\n",
        "                                        len(reached))\n",
        "                if s not in reached:\n",
        "                    reached.add(s)\n",
        "                    frontier.append(child)\n",
        "\n",
        "            max_frontier_size = max(max_frontier_size, len(frontier))\n",
        "\n",
        "        return SearchResult(algorithm, \"failure\", None,\n",
        "                            nodes_expanded, max_frontier_size, len(reached))"
      ],
      "metadata": {
        "id": "BZCQQOF_JLLe"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class DepthFirstSearch(SearchAlgorithm):\n",
        "    def search(self, problem):\n",
        "        algorithm = \"DFS\"\n",
        "        node = Node(problem.initial_state())\n",
        "        nodes_expanded = 0\n",
        "        max_frontier_size = 1\n",
        "\n",
        "        if problem.is_goal(node.state):\n",
        "            return SearchResult(algorithm, \"success\", node, 0, 1)\n",
        "\n",
        "        # use a stack so we go deep before going wide\n",
        "        frontier = [node]\n",
        "        reached = {node.state}\n",
        "\n",
        "        while frontier:\n",
        "            node = frontier.pop()\n",
        "            nodes_expanded += 1\n",
        "\n",
        "            ALL_children = list(self.expand(problem, node))\n",
        "            for child in reversed(ALL_children):\n",
        "                s = child.state\n",
        "                if problem.is_goal(s):\n",
        "                    return SearchResult(algorithm, \"success\", child,\n",
        "                                        nodes_expanded, max_frontier_size,\n",
        "                                        len(reached))\n",
        "                if s not in reached:\n",
        "                    reached.add(s)\n",
        "                    frontier.append(child)\n",
        "\n",
        "            max_frontier_size = max(max_frontier_size, len(frontier))\n",
        "\n",
        "        return SearchResult(algorithm, \"failure\", None,\n",
        "                            nodes_expanded, max_frontier_size, len(reached))"
      ],
      "metadata": {
        "id": "nh8SQkpZKm04"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class DepthLimitedSearch(SearchAlgorithm):\n",
        "    def search(self, problem, limit=10):\n",
        "        algorithm = \"DLS\"\n",
        "        initial_node = Node(problem.initial_state())\n",
        "        metrics = {\"nodes_expanded\": 0, \"max_stack_size\": 1}\n",
        "\n",
        "        solution, status = self._recursive_dls(problem, initial_node,\n",
        "                                                limit, metrics, 1)\n",
        "        return SearchResult(algorithm, status, solution,\n",
        "                            metrics[\"nodes_expanded\"],\n",
        "                            metrics[\"max_stack_size\"],\n",
        "                            reached_count=0, limit=limit)\n",
        "\n",
        "    def _recursive_dls(self, problem, node, limit, metrics, current_stack_size):\n",
        "        # found the goal\n",
        "        if problem.is_goal(node.state):\n",
        "            return node, \"success\"\n",
        "\n",
        "        # hit the depth wall, stop here\n",
        "        if node.depth >= limit:\n",
        "            return None, \"cutoff\"\n",
        "\n",
        "        metrics[\"nodes_expanded\"] += 1\n",
        "        cutoff_occurred = False\n",
        "\n",
        "        for child in self.expand(problem, node):\n",
        "            # skip if this state is already on our current path\n",
        "            if state_is_on_path(node, child.state):\n",
        "                continue\n",
        "\n",
        "            metrics[\"max_stack_size\"] = max(metrics[\"max_stack_size\"],\n",
        "                                            current_stack_size + 1)\n",
        "\n",
        "            result, status = self._recursive_dls(problem, child, limit,\n",
        "                                                  metrics, current_stack_size + 1)\n",
        "            if status == \"success\":\n",
        "                return result, \"success\"\n",
        "            if status == \"cutoff\":\n",
        "                cutoff_occurred = True\n",
        "\n",
        "        if cutoff_occurred:\n",
        "            return None, \"cutoff\"\n",
        "        return None, \"failure\""
      ],
      "metadata": {
        "id": "yZlSOl_nNREe"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class IterativeDeepeningSearch(SearchAlgorithm):\n",
        "    def search(self, problem, max_depth=50):\n",
        "        algorithm = \"IDS\"\n",
        "        total_nodes_expanded = 0\n",
        "        overall_max_stack = 0\n",
        "        iteration_log = []\n",
        "\n",
        "        dls = DepthLimitedSearch()\n",
        "\n",
        "        # keep raising the depth limit until we find the goal\n",
        "        for limit in range(max_depth + 1):\n",
        "            result = dls.search(problem, limit=limit)\n",
        "            total_nodes_expanded += result.nodes_expanded\n",
        "            overall_max_stack = max(overall_max_stack, result.max_frontier_size)\n",
        "            iteration_log.append({\"limit\": limit, \"status\": result.status})\n",
        "\n",
        "            if result.status == \"success\":\n",
        "                return SearchResult(algorithm, \"success\", result.solution,\n",
        "                                    total_nodes_expanded, overall_max_stack,\n",
        "                                    iterations=iteration_log)\n",
        "            if result.status == \"failure\":\n",
        "                return SearchResult(algorithm, \"failure\", None,\n",
        "                                    total_nodes_expanded, overall_max_stack,\n",
        "                                    iterations=iteration_log)\n",
        "\n",
        "        return SearchResult(algorithm, \"cutoff\", None,\n",
        "                            total_nodes_expanded, overall_max_stack,\n",
        "                            iterations=iteration_log)"
      ],
      "metadata": {
        "id": "U5hx4QIzNUmJ"
      },
